# Drive Point Exchange - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Site URL (for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# RESEND API (Primary Email Service)
# ============================================
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_API_KEY_HERE

# The verified "From" address for Resend
# Must be from a domain you've verified in Resend
MAIL_FROM="Drive Point Exchange <noreply@yourdomain.com>"

# ============================================
# Gmail SMTP (Fallback if Resend is not configured)
# ============================================
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# ============================================
# Owner Email
# ============================================
# This email receives notifications when customers request estimates
OWNER_EMAIL=support@yourdomain.com

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# Trustpilot Widget
# ============================================
NEXT_PUBLIC_TRUSTPILOT_TOKEN=your-trustpilot-token

# ============================================
# Social Feed Configuration
# ============================================
# Meta App client token — needed for Instagram + Facebook oEmbed
# Get from: developers.facebook.com > Your App > App Settings > Basic > App Token
META_APP_TOKEN=your-meta-app-token

# Curated post URLs (comma-separated)
SOCIAL_CURATED_URLS_TIKTOK=
SOCIAL_CURATED_URLS_INSTAGRAM=
SOCIAL_CURATED_URLS_FACEBOOK=
SOCIAL_CURATED_URLS_YOUTUBE=

# ============================================
# Google Generative AI (Image Generation)
# ============================================
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-api-key

# ============================================
# TikTok API
# ============================================
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ============================================
# Cron Jobs
# ============================================
CRON_SECRET=your-cron-secret

# ============================================
# Optional
# ============================================
# NODE_ENV=production
